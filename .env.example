# Bootstrap secrets only — everything else is configured in the web UI (stored in SQLite).

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b

# SMTP delivery (use an app password, not your real account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# Telegram delivery (optional) — create a bot via @BotFather, then run:
#   ./venv/bin/python main.py telegram-chatid     # discovers your chat id after you message the bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Paths (optional overrides)
DATA_DIR=data
DB_PATH=data/agent.db
STORAGE_STATE_PATH=auth/storage_state.json
